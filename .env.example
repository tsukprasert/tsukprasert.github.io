# Strava API Configuration
# Get your credentials at https://www.strava.com/settings/api

# Client ID - Safe to hardcode in JavaScript (public)
STRAVA_CLIENT_ID=your_client_id_here

# Client Secret - NEVER commit this to git!
# Store in GitHub Secrets for production use
STRAVA_CLIENT_SECRET=your_client_secret_here_DO_NOT_COMMIT

# Authorization Callback Domain
# For GitHub Pages: username.github.io
# For local testing: localhost:8000
REDIRECT_URI=https://your-username.github.io/running.html

# Note: For this static site, you'll hardcode CLIENT_ID in strava-auth.js
# The CLIENT_SECRET is only needed for server-side token refresh (future enhancement)
